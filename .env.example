# APwhy Go server port
APWHY_PORT=3001

# PostgreSQL database
# Local binary on host machine:
DATABASE_URL=postgresql://apwhy:apwhy123@localhost:5432/apwhy
# Docker Compose service-to-service host:
# DATABASE_URL=postgresql://apwhy:apwhy123@apwhy-db:5432/apwhy
# Railway: set DATABASE_URL from your Railway Postgres service variable.
APWHY_DB_PASSWORD=apwhy123

# Route prefix '/' disabled by default for protected services
ALLOW_ROOT_ROUTE_PREFIX=false
APWHY_PUBLIC_BASE_URL=http://localhost:3001

# Deploy runner
APWHY_DEPLOY_BASE_DIR=/data/deployments
BUILDKIT_HOST=docker-container://apwhy-buildkit
APWHY_DEPLOY_DOCKER_NETWORK=
APWHY_DEPLOY_PORT_START=18081
APWHY_DEPLOY_PORT_END=18150

# Umami analytics (JWT auth + script.js integration)
UMAMI_BASE_URL=
UMAMI_USERNAME=
UMAMI_PASSWORD=
UMAMI_SCRIPT_URL=
UMAMI_WEBSITE_ID=
