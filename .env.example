# APwhy Go server port
APWHY_PORT=3001

# SQLite control-plane database
SQLITE_DB_PATH=./data/apwhy.sqlite
# DATABASE_URL=file:/absolute/path/apwhy.sqlite

# UI mount path (use / for standalone)
DASHBOARD_UI_BASE_PATH=/
# Frontend build base path (must match DASHBOARD_UI_BASE_PATH for subpath deployments)
VITE_BASE_PATH=/

# API key routing header (for proxied upstream calls)
API_KEY_HEADER=x-api-key

# Internal token header injected to upstream protected services
SERVICE_TOKEN_HEADER=x-apwhy-service-token

# Route prefix '/' disabled by default for protected services
ALLOW_ROOT_ROUTE_PREFIX=false

# Default validation/proxy timeout in ms
DEFAULT_SERVICE_TIMEOUT_MS=8000

# Session and cookie settings
COOKIE_SECURE=false
COOKIE_DOMAIN=
SESSION_ACCESS_COOKIE=apwhy_access
SESSION_REFRESH_COOKIE=apwhy_refresh
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_HOURS=168

# Default plan limits
FREE_RPM=60
PRO_RPM=600
BUSINESS_RPM=3000
FREE_MONTHLY_QUOTA=1000
PRO_MONTHLY_QUOTA=50000
BUSINESS_MONTHLY_QUOTA=300000

# Umami API integration for traffic graphs
UMAMI_BASE_URL=http://localhost
UMAMI_API_KEY=
UMAMI_WEBSITE_ID=

# Docker + Traefik domains (used by deploy/docker-compose.yml)
APWHY_DOMAIN=apwhy.localhost
UMAMI_DOMAIN=umami.localhost
UMAMI_DB_PASSWORD=umami
UMAMI_HASH_SALT=change-me-very-long-random-salt
UMAMI_APP_SECRET=change-me-very-long-secret
