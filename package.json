{
  "name": "apwhy",
  "version": "1.0.0",
  "private": true,
  "description": "APwhy - self-hosted API routing and management control plane",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:api\" \"npm:dev:web\"",
    "dev:web": "vite",
    "dev:api": "go run ./cmd/apwhy",
    "build": "npm run build:web && npm run build:api",
    "build:web": "vite build",
    "build:api": "go build -o ./bin/apwhy ./cmd/apwhy",
    "typecheck": "npm run typecheck:web && npm run typecheck:api",
    "typecheck:web": "tsc --noEmit",
    "typecheck:api": "go test ./...",
    "start": "./bin/apwhy",
    "preview": "vite preview"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/manrope": "^5.2.8",
    "lucide-solid": "^0.575.0",
    "solid-js": "^1.9.9"
  },
  "devDependencies": {
    "@types/node": "^24.10.13",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-solid": "^2.11.9"
  }
}
